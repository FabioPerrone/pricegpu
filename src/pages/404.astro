---
import Layout from '../layouts/Layout.astro';
import { buildTitle, buildDescription, buildCanonical } from '../lib/seo.ts';

const title = buildTitle(['Page Not Found', 'PriceGPU']);
const description = buildDescription('Page not found. Browse GPU pricing, provider comparisons, and use case guides on PriceGPU.');
const canonical = buildCanonical('/404');
---

<Layout {title} {description} {canonical} noindex={true}>
  <div style="text-align: center; padding: 4rem 0;">
    <div style="font-size: 4rem; color: var(--text-dim); margin-bottom: 1rem;">404</div>
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">Page not found</h1>
    <p style="color: var(--text-muted); margin-bottom: 2rem;">This GPU may have been deprecated, or the URL changed.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/" class="btn-primary">← Home</a>
      <a href="/gpu/h100-80gb-sxm" style="display:inline-flex;align-items:center;border:1px solid var(--border);padding:0.6rem 1.2rem;border-radius:4px;font-size:0.9rem;color:var(--text-muted);">Compare H100 prices</a>
    </div>
  </div>
</Layout>