---
import Layout from '../../layouts/Layout.astro';
import CTA from '../../components/CTA.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import {
  getProviders, getProviderPrices, formatPrice, getRelatedProviders,
} from '../../lib/pricing.ts';
import {
  buildTitle, buildDescription, buildCanonical, buildBreadcrumbs, buildFAQSchema,
} from '../../lib/seo.ts';

export function getStaticPaths() {
  return getProviders().map((provider) => ({
    params: { provider: provider.slug },
    props: { provider },
  }));
}

const { provider } = Astro.props;
const related = getRelatedProviders(provider, 6);
const priceData = getProviderPrices(provider.slug);
const cheapestItem = priceData?.items.length
  ? priceData.items.reduce((a, b) => a.price_usd_per_hour < b.price_usd_per_hour ? a : b)
  : null;

const title = buildTitle([`${provider.name} Alternatives`, 'PriceGPU']);
const description = buildDescription(
  `Looking for ${provider.name} alternatives? Compare ${related.length} similar GPU cloud providers by price, regions, and features.`
);
const canonical = buildCanonical(`/${provider.slug}/alternatives`);

const faqs = [
  {
    q: `What are the best alternatives to ${provider.name}?`,
    a: `Top alternatives to ${provider.name} include: ${related.map((p) => p.name).join(', ')}, based on similar billing models, regions, and feature sets.`,
  },
  {
    q: `Is there a cheaper alternative to ${provider.name}?`,
    a: cheapestItem
      ? `${provider.name}'s entry price is ${formatPrice(cheapestItem.price_usd_per_hour)}/hr. Compare with ${related[0]?.name ?? 'other providers'} to find lower prices for your GPU model.`
      : `Compare providers on the PriceGPU tables to find cheaper options.`,
  },
  {
    q: `Which ${provider.name} alternative has the most regions?`,
    a: `${related.sort((a, b) => b.regions.length - a.regions.length)[0]?.name ?? 'N/A'} has the most regional coverage among similar providers.`,
  },
];

const schemas = [
  buildBreadcrumbs([
    { name: 'Home', url: '/' },
    { name: provider.name, url: `/provider/${provider.slug}` },
    { name: 'Alternatives', url: canonical },
  ]),
  buildFAQSchema(faqs),
];

const relatedLinks = [
  { title: `${provider.name} pricing`, url: `/provider/${provider.slug}`, description: provider.description },
  ...related.map((p) => ({
    title: `${provider.name} vs ${p.name}`,
    url: `/compare/${provider.slug}-vs-${p.slug}`,
    description: `Side-by-side comparison`,
  })),
];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb">
    <a href="/">Home</a><span>/</span>
    <a href={`/provider/${provider.slug}`}>{provider.name}</a><span>/</span>
    <span>Alternatives</span>
  </nav>

  <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">
    {provider.name} Alternatives
  </h1>
  <p style="color: var(--text-muted); margin-bottom: 2rem;">
    {related.length} providers with similar billing, regions, and GPU offerings.
  </p>

  <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
    {related.map((alt) => {
      const altPrices = getProviderPrices(alt.slug);
      const altCheapest = altPrices?.items.length
        ? altPrices.items.reduce((a, b) => a.price_usd_per_hour < b.price_usd_per_hour ? a : b)
        : null;
      return (
        <div class="card" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
          <div>
            <div style="display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap;">
              <a href={`/provider/${alt.slug}`} style="font-weight: 600; font-size: 1rem;">{alt.name}</a>
              {altCheapest && (
                <span style="color: var(--text-muted); font-size: 0.85rem;">
                  from <strong class="accent">{formatPrice(altCheapest.price_usd_per_hour)}</strong>/hr
                </span>
              )}
            </div>
            <div style="font-size: 0.85rem; color: var(--text-muted); margin-top: 0.25rem;">{alt.description}</div>
            <div style="font-size: 0.8rem; color: var(--text-dim); margin-top: 0.25rem;">
              {alt.regions.join(' · ')} &nbsp;·&nbsp; {alt.features.join(', ')}
            </div>
          </div>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href={`/compare/${provider.slug}-vs-${alt.slug}`} class="btn-primary" style="background: var(--bg-card); color: var(--text); border: 1px solid var(--border); font-size: 0.8rem; padding: 0.35rem 0.8rem;">Compare →</a>
            <CTA providerSlug={alt.slug} providerName={alt.name} variant="inline" />
          </div>
        </div>
      );
    })}
  </div>

  <section style="margin-top: 1rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">FAQ</h2>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {faqs.map((faq) => (
        <div class="card">
          <div style="font-weight: 600; margin-bottom: 0.4rem;">{faq.q}</div>
          <div style="color: var(--text-muted); font-size: 0.9rem;">{faq.a}</div>
        </div>
      ))}
    </div>
  </section>

  <RelatedPages links={relatedLinks} heading="Related Pages" />
</Layout>