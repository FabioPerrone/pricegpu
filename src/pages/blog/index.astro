---
import Layout from '../../layouts/Layout.astro';
import { buildTitle, buildDescription, buildCanonical, buildBreadcrumbs } from '../../lib/seo.ts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = buildTitle(['Blog', 'PriceGPU']);
const description = buildDescription('Cloud GPU pricing guides and analysis for ML engineers. Spot vs on-demand, H100 vs A100, LLM inference sizing, and more.');
const canonical = buildCanonical('/blog');
const schemas = [buildBreadcrumbs([{ name: 'Home', url: '/' }, { name: 'Blog', url: '/blog' }])];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb">
    <a href="/">Home</a><span>/</span><span>Blog</span>
  </nav>

  <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1.5rem;">Blog</h1>

  {posts.length === 0 ? (
    <p style="color: var(--text-muted);">No posts yet — check back soon.</p>
  ) : (
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {posts.map((post) => (
        <a href={`/blog/${post.data.slug}`} class="card" style="text-decoration: none;">
          <div style="display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.5rem;">
            <h2 style="font-size: 1.05rem; font-weight: 600;">{post.data.title}</h2>
            <time style="font-size: 0.8rem; color: var(--text-dim);" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </time>
          </div>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin: 0;">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div style="display: flex; gap: 0.4rem; margin-top: 0.75rem; flex-wrap: wrap;">
              {post.data.tags.map((tag) => (
                <span class="badge badge-gray">{tag}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  )}
</Layout>
