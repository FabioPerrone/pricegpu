---
import Layout from '../../layouts/Layout.astro';
import PriceTable from '../../components/PriceTable.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import CTA from '../../components/CTA.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import {
  getProviders, getGPUs, getAllPrices, formatPrice, getLastScrapeDate,
} from '../../lib/pricing.ts';
import {
  buildTitle, buildDescription, buildCanonical, buildBreadcrumbs, buildFAQSchema,
} from '../../lib/seo.ts';

export function getStaticPaths() {
  const providers = getProviders();
  const paths = [];
  for (let i = 0; i < providers.length; i++) {
    for (let j = i + 1; j < providers.length; j++) {
      paths.push({
        params: { a: providers[i].slug, b: providers[j].slug },
        props: { providerA: providers[i], providerB: providers[j] },
      });
    }
  }
  return paths;
}

const { providerA, providerB } = Astro.props;
const gpus = getGPUs();
const allPrices = getAllPrices();

const pricesA = allPrices
  .filter((p) => p.provider_slug === providerA.slug)
  .map((p) => ({ ...p, provider_name: providerA.name }))
  .sort((a, b) => a.price_usd_per_hour - b.price_usd_per_hour)
  .slice(0, 8);

const pricesB = allPrices
  .filter((p) => p.provider_slug === providerB.slug)
  .map((p) => ({ ...p, provider_name: providerB.name }))
  .sort((a, b) => a.price_usd_per_hour - b.price_usd_per_hour)
  .slice(0, 8);

const cheapestA = pricesA[0];
const cheapestB = pricesB[0];
const cheaperProvider = cheapestA && cheapestB
  ? cheapestA.price_usd_per_hour <= cheapestB.price_usd_per_hour ? providerA : providerB
  : null;

const scrapedAt = getLastScrapeDate(providerA.slug);

const title = buildTitle([`${providerA.name} vs ${providerB.name}`, 'GPU Cloud Comparison', 'PriceGPU']);
const description = buildDescription(
  `${providerA.name} vs ${providerB.name}: side-by-side GPU pricing, features, and regions. ${cheaperProvider ? `${cheaperProvider.name} offers lower entry pricing.` : ''} Updated weekly.`
);
const canonical = buildCanonical(`/compare/${providerA.slug}-vs-${providerB.slug}`);

const faqs = [
  {
    q: `Which is cheaper, ${providerA.name} or ${providerB.name}?`,
    a: cheapestA && cheapestB
      ? `${providerA.name}'s lowest price is ${formatPrice(cheapestA.price_usd_per_hour)}/hr; ${providerB.name}'s is ${formatPrice(cheapestB.price_usd_per_hour)}/hr. ${cheaperProvider?.name} has the lower entry price, but the cheapest option depends on your specific GPU model and region.`
      : 'Pricing data is being updated. Check back after the next scrape.',
  },
  {
    q: `What regions do ${providerA.name} and ${providerB.name} support?`,
    a: `${providerA.name} supports: ${providerA.regions.join(', ')}. ${providerB.name} supports: ${providerB.regions.join(', ')}.`,
  },
  {
    q: `How do the billing models compare?`,
    a: `${providerA.name} bills ${providerA.billing.join('/')}. ${providerB.name} bills ${providerB.billing.join('/')}.`,
  },
  {
    q: `Which provider has more GPU options?`,
    a: `${providerA.name} lists ${pricesA.length} configurations; ${providerB.name} lists ${pricesB.length} configurations in our dataset.`,
  },
  {
    q: `Are spot instances available on both providers?`,
    a: `${providerA.features.includes('spot') ? providerA.name + ' offers spot instances.' : providerA.name + ' does not list spot instances.'} ${providerB.features.includes('spot') ? providerB.name + ' offers spot instances.' : providerB.name + ' does not list spot instances.'}`,
  },
];

const schemas = [
  buildBreadcrumbs([
    { name: 'Home', url: '/' },
    { name: 'Compare', url: '/compare' },
    { name: `${providerA.name} vs ${providerB.name}`, url: canonical },
  ]),
  buildFAQSchema(faqs),
];

const otherProviders = getProviders().filter(
  (p) => p.slug !== providerA.slug && p.slug !== providerB.slug
).slice(0, 4);

const relatedLinks = [
  { title: `${providerA.name} pricing`, url: `/provider/${providerA.slug}`, description: providerA.description },
  { title: `${providerB.name} pricing`, url: `/provider/${providerB.slug}`, description: providerB.description },
  { title: `${providerA.name} alternatives`, url: `/${providerA.slug}/alternatives`, description: `Providers similar to ${providerA.name}` },
  { title: `${providerB.name} alternatives`, url: `/${providerB.slug}/alternatives`, description: `Providers similar to ${providerB.name}` },
  ...otherProviders.map((p) => ({ title: `${providerA.name} vs ${p.name}`, url: `/compare/${providerA.slug}-vs-${p.slug}`, description: undefined })),
];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb">
    <a href="/">Home</a><span>/</span><a href="/compare">Compare</a><span>/</span>
    <span>{providerA.name} vs {providerB.name}</span>
  </nav>

  <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.5rem;">
    {providerA.name} vs {providerB.name}
  </h1>

  {cheaperProvider && (
    <div class="verdict-box" style="margin-bottom: 1.5rem;">
      <strong class="accent">{cheaperProvider.name}</strong> offers the lower entry price
      {cheapestA && cheapestB && (
        <span style="color:var(--text-muted);">
          &nbsp;({formatPrice(Math.min(cheapestA.price_usd_per_hour, cheapestB.price_usd_per_hour))}/hr vs {formatPrice(Math.max(cheapestA.price_usd_per_hour, cheapestB.price_usd_per_hour))}/hr).
        </span>
      )}
      Best choice depends on GPU model, region, and workload.
    </div>
  )}

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
    <CTA providerSlug={providerA.slug} providerName={providerA.name} variant="inline" />
    <CTA providerSlug={providerB.slug} providerName={providerB.name} variant="inline" />
  </div>

  <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">Feature Comparison</h2>
  <ComparisonTable {providerA} {providerB} />

  <h2 style="font-size: 1.1rem; margin: 2rem 0 1rem;">{providerA.name} — Top Prices</h2>
  <PriceTable prices={pricesA} {scrapedAt} />

  <h2 style="font-size: 1.1rem; margin: 2rem 0 1rem;">{providerB.name} — Top Prices</h2>
  <PriceTable prices={pricesB} scrapedAt={getLastScrapeDate(providerB.slug)} />

  <section style="margin-top: 2.5rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">FAQ</h2>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {faqs.map((faq) => (
        <div class="card">
          <div style="font-weight: 600; margin-bottom: 0.4rem;">{faq.q}</div>
          <div style="color: var(--text-muted); font-size: 0.9rem;">{faq.a}</div>
        </div>
      ))}
    </div>
  </section>

  {cheaperProvider && (
    <div style="margin-top: 2rem;">
      <CTA
        providerSlug={cheaperProvider.slug}
        providerName={cheaperProvider.name}
        headline={`Try ${cheaperProvider.name} →`}
        note="Affiliate link — we may earn a commission at no cost to you."
      />
    </div>
  )}

  {scrapedAt && (
    <p style="margin-top: 1.5rem; font-size: 0.8rem; color: var(--text-dim);">
      Last data refresh: {new Date(scrapedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}. Verify pricing on provider sites.
    </p>
  )}

  <RelatedPages links={relatedLinks} heading="Related Comparisons" />
</Layout>