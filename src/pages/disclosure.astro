---
import Layout from '../layouts/Layout.astro';
import { buildTitle, buildDescription, buildCanonical, buildBreadcrumbs } from '../lib/seo.ts';
import { getProviders } from '../lib/pricing.ts';

const providers = getProviders();
const affiliateProviders = providers.filter((p) => p.affiliate_url_template);
const title = buildTitle(['Affiliate Disclosure', 'PriceGPU']);
const description = buildDescription('PriceGPU affiliate disclosure. We earn commissions from some cloud GPU providers when you use our referral links.');
const canonical = buildCanonical('/disclosure');
const schemas = [buildBreadcrumbs([{ name: 'Home', url: '/' }, { name: 'Disclosure', url: '/disclosure' }])];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>Affiliate Disclosure</span></nav>
  <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1.5rem;">Affiliate Disclosure</h1>
  <div class="prose">
    <p>PriceGPU participates in affiliate and referral programs. When you click a "Rent →" or "Try [Provider]" link, we may receive a commission — <strong>at no cost to you</strong>.</p>
    <h2>Editorial independence</h2>
    <ul>
      <li><strong>Table ordering</strong> — sorted by price only, lowest first.</li>
      <li><strong>Provider inclusion</strong> — all major providers listed regardless of affiliate status.</li>
      <li><strong>Pricing data</strong> — scraped from provider sites, not provided by providers.</li>
    </ul>
    <h2>Affiliate programs we participate in</h2>
    <ul>{affiliateProviders.map((p) => <li><a href={`/provider/${p.slug}`}>{p.name}</a></li>)}</ul>
    <h2>Link cloaking</h2>
    <p>Affiliate links go through <code>/go/[provider]</code> redirects. All outbound affiliate links carry <code>rel="sponsored noopener"</code> per Google's guidelines.</p>
  </div>
</Layout>