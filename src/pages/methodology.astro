---
import Layout from '../layouts/Layout.astro';
import { buildTitle, buildDescription, buildCanonical, buildBreadcrumbs } from '../lib/seo.ts';
import { getProviders } from '../lib/pricing.ts';

const providers = getProviders();
const title = buildTitle(['Methodology', 'PriceGPU']);
const description = buildDescription('How PriceGPU collects, validates, and publishes cloud GPU pricing data.');
const canonical = buildCanonical('/methodology');
const schemas = [buildBreadcrumbs([{ name: 'Home', url: '/' }, { name: 'Methodology', url: '/methodology' }])];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb"><a href="/">Home</a><span>/</span><span>Methodology</span></nav>
  <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 1.5rem;">Methodology</h1>
  <div class="prose">
    <h2>Data collection</h2>
    <p>Pricing is scraped weekly (Monday 03:00 UTC) using Playwright (headless Chromium). Each scraper navigates to the provider's pricing page, waits for content to render, extracts GPU model names and per-hour prices, maps names to canonical slugs, and validates output against a Zod schema.</p>
    <h2>Rate limiting</h2>
    <p>Scrapers throttle to 1 request per 2 seconds. User-Agent: <code>pricegpu.com/1.0 (+https://pricegpu.com/about)</code>.</p>
    <h2>Data accuracy</h2>
    <p>Prices reflect publicly listed on-demand rates at scrape time. Actual billing may differ due to promotions, spot pricing, minimum billing periods, or prices changing between weekly scrapes. Every table shows "as of [date], verify on provider site".</p>
    <h2>Open data</h2>
    <p>Raw price dataset at <a href="/api/prices.json">/api/prices.json</a> under CC-BY-4.0. Scraper source code in the <a href="https://github.com/fabioperrone/pricegpu" rel="noopener">public GitHub repository</a>.</p>
    <h2>Providers tracked</h2>
    <p>{providers.map((p) => p.name).join(' · ')}</p>
  </div>
</Layout>