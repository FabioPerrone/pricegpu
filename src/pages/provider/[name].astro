---
import Layout from '../../layouts/Layout.astro';
import PriceTable from '../../components/PriceTable.astro';
import CTA from '../../components/CTA.astro';
import RelatedPages from '../../components/RelatedPages.astro';
import {
  getProviders, getGPUs, getProviderPrices, formatPrice,
  getRelatedProviders, getLastScrapeDate,
} from '../../lib/pricing.ts';
import {
  buildTitle, buildDescription, buildCanonical, buildBreadcrumbs, buildFAQSchema,
} from '../../lib/seo.ts';

export function getStaticPaths() {
  return getProviders().map((provider) => ({
    params: { name: provider.slug },
    props: { provider },
  }));
}

const { provider } = Astro.props;
const gpus = getGPUs();
const priceData = getProviderPrices(provider.slug);
const prices = (priceData?.items ?? []).map((item) => {
  const gpu = gpus.find((g) => g.slug === item.gpu_slug);
  return { ...item, provider_slug: provider.slug, provider_name: provider.name, gpu_name: gpu?.name };
});
const relatedProviders = getRelatedProviders(provider, 6);
const scrapedAt = getLastScrapeDate(provider.slug);

const cheapestItem = prices.length > 0
  ? prices.reduce((a, b) => a.price_usd_per_hour < b.price_usd_per_hour ? a : b)
  : null;

const title = buildTitle([`${provider.name} GPU Cloud Pricing`, 'PriceGPU']);
const description = buildDescription(
  `${provider.name} GPU rental pricing: ${prices.length} configurations available${cheapestItem ? `, from ${formatPrice(cheapestItem.price_usd_per_hour)}/hr` : ''}. ${provider.description}`
);
const canonical = buildCanonical(`/provider/${provider.slug}`);

const faqs = [
  {
    q: `What GPUs does ${provider.name} offer?`,
    a: [...new Set(prices.map((p) => p.configuration))].join(', ') || 'See provider site for current availability.',
  },
  {
    q: `Where are ${provider.name} data centers located?`,
    a: `${provider.name} operates in: ${provider.regions.join(', ')}.`,
  },
  {
    q: `How does ${provider.name} bill for GPU usage?`,
    a: `${provider.name} supports ${provider.billing.join(' and ')} billing.`,
  },
  {
    q: `Is ${provider.name} reliable for production workloads?`,
    a: `${provider.name} has a trust score of ${provider.trust_score}/5 on PriceGPU. Features include: ${provider.features.join(', ')}.`,
  },
];

const schemas = [
  buildBreadcrumbs([
    { name: 'Home', url: '/' },
    { name: 'Providers', url: '/provider' },
    { name: provider.name, url: `/provider/${provider.slug}` },
  ]),
  buildFAQSchema(faqs),
];

const relatedLinks = [
  ...relatedProviders.map((p) => ({
    title: p.name,
    url: `/provider/${p.slug}`,
    description: p.description,
  })),
  { title: `${provider.name} alternatives`, url: `/${provider.slug}/alternatives`, description: `Compare with similar providers` },
];
---

<Layout {title} {description} {canonical} {schemas}>
  <nav class="breadcrumb">
    <a href="/">Home</a><span>/</span><a href="/provider">Providers</a><span>/</span><span>{provider.name}</span>
  </nav>

  <div style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
    <h1 style="font-size: 1.75rem; font-weight: 700;">{provider.name} GPU Cloud Pricing</h1>
    {cheapestItem && (
      <span style="font-size: 1.1rem; color: var(--text-muted);">
        from <strong class="accent">{formatPrice(cheapestItem.price_usd_per_hour)}</strong>/hr
      </span>
    )}
  </div>
  <p style="color: var(--text-muted); margin-bottom: 1.5rem;">{provider.description}</p>

  <div style="margin-bottom: 1.5rem;">
    <CTA providerSlug={provider.slug} providerName={provider.name} />
  </div>

  <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">Current Pricing — {prices.length} configurations</h2>
  <PriceTable {prices} {scrapedAt} />

  <section style="margin-top: 2.5rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">Provider Details</h2>
    <div class="card" style="padding: 0; overflow: hidden;">
      <table>
        <tbody>
          <tr><td style="color:var(--text-muted);">Founded</td><td>{provider.founded}</td></tr>
          <tr><td style="color:var(--text-muted);">Billing</td><td>{provider.billing.join(', ')}</td></tr>
          <tr><td style="color:var(--text-muted);">Regions</td><td>{provider.regions.join(', ')}</td></tr>
          <tr><td style="color:var(--text-muted);">Features</td><td>{provider.features.join(', ')}</td></tr>
          <tr><td style="color:var(--text-muted);">Trust Score</td><td>{provider.trust_score}/5</td></tr>
          <tr>
            <td style="color:var(--text-muted);">Website</td>
            <td><a href={provider.url} rel="noopener" target="_blank">{provider.url}</a></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section style="margin-top: 2.5rem;">
    <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">FAQ</h2>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {faqs.map((faq) => (
        <div class="card">
          <div style="font-weight: 600; margin-bottom: 0.4rem;">{faq.q}</div>
          <div style="color: var(--text-muted); font-size: 0.9rem;">{faq.a}</div>
        </div>
      ))}
    </div>
  </section>

  {scrapedAt && (
    <p style="margin-top: 1.5rem; font-size: 0.8rem; color: var(--text-dim);">
      Last data refresh: {new Date(scrapedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}. Prices are indicative — verify on {provider.name}'s site before purchasing.
    </p>
  )}

  <RelatedPages links={relatedLinks} heading="Related Providers" />
</Layout>
